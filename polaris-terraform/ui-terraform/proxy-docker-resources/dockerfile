FROM nginx
ENV CLASSIC_CORS_CIN2="10.2.177.3;cin2.cps.gov.uk"
ENV CLASSIC_FARN_CIN2="10.2.177.3;cin2.cps.gov.uk"
ENV MODERN_CORS_CIN2="10.2.177.67;cmsmodcin2.cps.gov.uk"
ENV MODERN_FARN_CIN2="10.2.177.67;cmsmodcin2.cps.gov.uk"
ENV CLASSIC_CORS_CIN3=""
ENV CLASSIC_FARN_CIN3=""
ENV MODERN_CORS_CIN3=""
ENV MODERN_FARN_CIN3=""
ENV CLASSIC_CORS_CIN5="10.2.177.21;cin5.cps.gov.uk"
ENV CLASSIC_FARN_CIN5="10.2.177.21;cin5.cps.gov.uk"
ENV MODERN_CORS_CIN5="10.2.177.67;cmsmodcin5.cps.gov.uk"
ENV MODERN_FARN_CIN5="10.2.177.67;cmsmodcin5.cps.gov.uk"
ENV CLASSIC_CORS_DEFAULT="10.2.177.14;cin3.cps.gov.uk"
ENV CLASSIC_FARN_DEFAULT="10.2.177.14;cin3.cps.gov.uk"
ENV MODERN_CORS_DEFAULT="10.2.177.67;cmsmodcin3.cps.gov.uk"
ENV MODERN_FARN_DEFAULT="10.2.177.67;cmsmodcin3.cps.gov.uk"
ADD . CLASSIC_CORS_CIN2
ADD . CLASSIC_FARN_CIN2
ADD . MODERN_CORS_CIN2
ADD . MODERN_FARN_CIN2
ADD . CLASSIC_CORS_CIN3
ADD . CLASSIC_FARN_CIN3
ADD . MODERN_CORS_CIN3
ADD . MODERN_FARN_CIN3
ADD . CLASSIC_CORS_CIN5
ADD . CLASSIC_FARN_CIN5
ADD . MODERN_CORS_CIN5
ADD . MODERN_FARN_CIN5
ADD . CLASSIC_CORS_DEFAULT
ADD . CLASSIC_FARN_DEFAULT
ADD . MODERN_CORS_DEFAULT
ADD . MODERN_FARN_DEFAULT
RUN rm /etc/nginx/conf.d/default.conf
COPY nginx.conf /etc/nginx
COPY nginx.js /etc/nginx
COPY polaris-script.js /etc/nginx
EXPOSE 80 
CMD ["nginx", "-g", "daemon off;"]